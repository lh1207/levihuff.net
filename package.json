{
  "name": "levihuff.net",
  "version": "1.0.0",
  "description": "Personal portfolio website of Levi Huff",
  "scripts": {
    "start": "npm run build && npm-run-all --parallel dev:11ty dev:css",
    "dev:11ty": "eleventy --serve",
    "dev:css": "tailwindcss -i ./src/_includes/css/tailwind.css -o ./_site/css/styles.css --watch",
    "build": "eleventy && tailwindcss -i ./src/_includes/css/tailwind.css -o ./_site/css/styles.css --minify",
    "watch": "eleventy --watch",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@11ty/eleventy": "^2.0.1"
  },
  "devDependencies": {
    "@11ty/eleventy-plugin-rss": "^1.2.0",
    "@11ty/eleventy-plugin-syntaxhighlight": "^4.2.0",
    "autoprefixer": "^10.5.0",
    "cssnano": "^7.1.7",
    "markdown-it": "^14.1.1",
    "markdown-it-anchor": "^8.6.7",
    "npm-run-all": "^4.1.5",
    "postcss": "^8.5.12",
    "tailwindcss": "^3.4.19",
    "vitest": "^4.1.5"
  }
}
