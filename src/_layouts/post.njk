---
layout: base.njk
isPost: true
---

<article>
  <header class="post-header">
    <h1>{{ title }}</h1>
    {% if description %}
    <p class="lead">{{ description }}</p>
    {% endif %}
    <div class="blog-meta">
      {% if date %}
      <time datetime="{{ date | dateIso }}">{{ date | dateReadable }}</time>
      {% endif %}
      <span class="reading-time">{{ content | readingTime }}</span>
      {% if tags %}
      <div class="tag-list">
        {% for tag in tags %}
        <a href="/tags/{{ tag | tagSlug }}/" class="tag">{{ tag }}</a>
        {% endfor %}
      </div>
      {% endif %}
    </div>
  </header>

  <div class="post-content">
    {{ content | safe }}
  </div>

  <footer class="post-footer">
    {%- set previousPost = collections.posts | getPreviousCollectionItem -%}
    {%- set nextPost = collections.posts | getNextCollectionItem -%}
    <nav class="post-nav" aria-label="Post navigation">
      <div class="post-nav-prev">
        {% if previousPost %}
        <a href="{{ previousPost.url }}" rel="prev">&larr; {{ previousPost.data.title }}</a>
        {% endif %}
      </div>
      <a href="/blog/" class="back-link">All posts</a>
      <div class="post-nav-next">
        {% if nextPost %}
        <a href="{{ nextPost.url }}" rel="next">{{ nextPost.data.title }} &rarr;</a>
        {% endif %}
      </div>
    </nav>
  </footer>
</article>

<script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@type": "BlogPosting",
  "headline": {{ title | dump | safe }},
  "description": {{ description | dump | safe }},
  "datePublished": "{{ date | dateIso }}",
  "author": {
    "@type": "Person",
    "name": "{{ site.name }}",
    "url": "{{ site.url }}"
  },
  "image": "{% if thumbnail %}{{ site.url }}{{ thumbnail }}{% else %}{{ site.url }}/images/profile.jpg{% endif %}",
  "mainEntityOfPage": {
    "@type": "WebPage",
    "@id": "{{ site.url }}{{ page.url }}"
  }
}
</script>
