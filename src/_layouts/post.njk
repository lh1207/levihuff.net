---
layout: base.njk
isPost: true
---

<article>
  <header class="post-header">
    <h1>{{ title }}</h1>
    {% if description %}
    <p class="lead">{{ description }}</p>
    {% endif %}
    <div class="blog-meta">
      {% if date %}
      <time datetime="{{ date | dateIso }}">{{ date | dateReadable }}</time>
      {% endif %}
      <span class="reading-time">{{ content | readingTime }}</span>
      {% if tags %}
      <div class="tag-list">
        {% for tag in tags %}
        <span class="tag">{{ tag }}</span>
        {% endfor %}
      </div>
      {% endif %}
    </div>
  </header>

  <div class="post-content">
    {{ content | safe }}
  </div>

  <footer class="post-footer">
    <div class="post-nav">
      <p class="post-author">Written by {{ site.name }}</p>
      <a href="/blog/" class="back-link">&larr; Back to Blog</a>
    </div>
  </footer>
</article>

<script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@type": "BlogPosting",
  "headline": {{ title | dump | safe }},
  "description": {{ description | dump | safe }},
  "datePublished": "{{ date | dateIso }}",
  "author": {
    "@type": "Person",
    "name": "{{ site.name }}",
    "url": "{{ site.url }}"
  },
  "image": "{% if thumbnail %}{{ site.url }}{{ thumbnail }}{% else %}{{ site.url }}/images/profile.jpg{% endif %}",
  "mainEntityOfPage": {
    "@type": "WebPage",
    "@id": "{{ site.url }}{{ page.url }}"
  }
}
</script>
