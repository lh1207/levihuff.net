---
layout: base.njk
title: Blog | Levi Huff
description: Technical blog posts covering full-stack development, systems administration, accessibility, and process improvement in IT.
---

<section>
  <div class="blog-index-header">
    <div>
      <h1>Blog</h1>
      <p class="lead">Technical insights, project updates, and professional reflections</p>
    </div>
    <a href="/feed.xml" class="rss-link" aria-label="Subscribe via RSS feed">
      <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M6.18 15.64a2.18 2.18 0 0 1 2.18 2.18C8.36 19.01 7.38 20 6.18 20C4.98 20 4 19.01 4 17.82a2.18 2.18 0 0 1 2.18-2.18M4 4.44A15.56 15.56 0 0 1 19.56 20h-2.83A12.73 12.73 0 0 0 4 7.27V4.44m0 5.66a9.9 9.9 0 0 1 9.9 9.9h-2.83A7.07 7.07 0 0 0 4 12.93V10.1z"/></svg>
      RSS
    </a>
  </div>

  {% if collections.posts.length > 0 %}
  <div class="blog-grid">
    {% for post in collections.posts | reverse %}
    <article class="blog-card">
      {% if post.data.thumbnail %}
      <img src="{{ post.data.thumbnail }}" alt="" class="blog-thumbnail{% if post.data.thumbnailLogo %} logo{% endif %}" loading="lazy">
      {% endif %}
      <h2>
        <a href="{{ post.url }}">{{ post.data.title }}</a>
      </h2>
      {% if post.data.description %}
      <p>{{ post.data.description }}</p>
      {% endif %}
      <div class="blog-meta">
        {% if post.date %}
        <time datetime="{{ post.date | dateIso }}">{{ post.date | dateReadable }}</time>
        {% endif %}
        <span class="reading-time">{{ post.templateContent | readingTime }}</span>
        {% if post.data.tags %}
        <div class="tag-list">
          {% for tag in post.data.tags %}
          <span class="tag">{{ tag }}</span>
          {% endfor %}
        </div>
        {% endif %}
      </div>
    </article>
    {% endfor %}
  </div>
  {% else %}
  <div class="empty-state">
    <h2>Coming Soon</h2>
    <p>Blog posts are being prepared and will be available soon.</p>
  </div>
  {% endif %}
</section>
