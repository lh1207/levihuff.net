<header>
  <div class="header-inner">
    <a class="brand" href="/">
      <img src="/images/profile.jpg" alt="Levi Huff" class="profile-img">
      <span class="brand-name">Levi Huff</span>
    </a>
    <nav>
      <ul>
        {% for item in navigation %}
          <li><a href="{{ item.url }}" {% if page.url == item.url %}aria-current="page"{% endif %}>{{ item.label }}</a></li>
        {% endfor %}
      </ul>
    </nav>
  </div>
</header>
