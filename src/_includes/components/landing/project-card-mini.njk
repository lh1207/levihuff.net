<article class="bg-surface-2 border border-hair-1 rounded-d-lg overflow-hidden hover:border-hair-2 hover:-translate-y-0.5 hover:shadow-d-md transition-[transform,border-color,box-shadow] duration-[180ms]">
  {% if project.image %}
    <img
      src="{{ project.image }}"
      alt="{{ project.imageAlt }}"
      class="w-full h-48 object-cover bg-surface-3"
      width="{{ project.imageWidth }}"
      height="{{ project.imageHeight }}"
      loading="lazy">
  {% endif %}
  <div class="p-6">
    <p class="font-jb text-mono-xs tracking-[0.04em] uppercase text-fg-3">STACK · {{ project.stack }}</p>
    <h3 class="font-plex text-xl font-semibold text-fg-1 mt-2 leading-snug">
      {% if project.link %}
        <a href="{{ project.link }}" target="_blank" rel="noopener" class="hover:text-amber transition-colors duration-[120ms] focus-visible:outline-[3px] focus-visible:outline-amber focus-visible:outline-offset-2">{{ project.title }}</a>
      {% else %}
        {{ project.title }}
      {% endif %}
    </h3>
    <p class="font-plex text-base text-fg-2 mt-3 leading-relaxed">{{ project.summary }}</p>
    {% if project.link %}
      <p class="mt-5">
        <a href="{{ project.link }}" target="_blank" rel="noopener" class="font-jb text-sm text-amber hover:text-amber-hi transition-colors duration-[120ms] focus-visible:outline-[3px] focus-visible:outline-amber focus-visible:outline-offset-2">View &rarr;</a>
      </p>
    {% endif %}
  </div>
</article>
