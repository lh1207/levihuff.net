  "url": "{{ site.url }}",
  "jobTitle": "IT Student & Developer",
  "alumniOf": {
    "@type": "CollegeOrUniversity",
    "name": "University of Cincinnati"
  },
  "sameAs": [
    "{{ site.social.github }}",
    "{{ site.social.linkedin }}"
  ]
}
</script>
