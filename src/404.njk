layout: base.njk
permalink: /404.html
eleventyExcludeFromCollections: true
title: 404 | Levi Huff
---

<div class="bg-surface-1 text-fg-1">
  <section class="py-20 md:py-32">
    <div class="max-w-site mx-auto px-4 md:px-6 text-center">

      <p class="font-syne text-5xl font-bold tracking-[-0.02em] text-fg-3">404</p>
      <h1 class="font-syne text-3xl font-semibold leading-snug tracking-[-0.02em] text-fg-1 mt-4">Page not found.</h1>
      <p class="font-plex text-lg text-fg-2 leading-relaxed mt-4 max-w-prose mx-auto">That page does not exist or may have moved. Try one of these instead.</p>

      <nav aria-label="Error page navigation" class="mt-10">
        <ul class="flex flex-wrap justify-center gap-3">
          {% for item in navigation %}
          <li>
            <a
              href="{{ item.url }}"
              class="inline-flex items-center font-jb text-sm text-fg-2 bg-surface-2 border border-hair-1 hover:border-hair-2 hover:text-fg-1 px-4 py-2 rounded-d-md transition-colors duration-[120ms] focus-visible:outline-[3px] focus-visible:outline-amber focus-visible:outline-offset-2">
              {{ item.label }}
            </a>
          </li>
          {% endfor %}
        </ul>
      </nav>

    </div>
  </section>
</div>
